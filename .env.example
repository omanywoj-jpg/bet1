# Environment Variables Template

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=3000
NODE_ENV=development

# ========================================
# M-PESA CONFIGURATION
# ========================================
MPESA_CONSUMER_KEY=YOUR_CONSUMER_KEY_HERE
MPESA_CONSUMER_SECRET=YOUR_CONSUMER_SECRET_HERE
MPESA_BUSINESS_SHORT_CODE=YOUR_BUSINESS_CODE_HERE
MPESA_PASSKEY=YOUR_PASSKEY_HERE
MPESA_SECURITY_CREDENTIAL=YOUR_ENCRYPTED_CREDENTIAL_HERE
MPESA_API_URL=https://sandbox.safaricom.co.ke
CALLBACK_URL=https://your-domain.com/api/mpesa/callback

# ========================================
# EMAIL CONFIGURATION (Gmail)
# ========================================
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-16-chars

# ========================================
# OWNER CONTACT INFORMATION
# ========================================
OWNER_EMAIL=owner@example.com
OWNER_PHONE=+254799941621

# ========================================
# AFRICA'S TALKING SMS CONFIGURATION
# ========================================
AFRICAS_TALKING_USERNAME=your-username
AFRICAS_TALKING_API_KEY=your-api-key

# ========================================
# WEBHOOK CONFIGURATION (OPTIONAL)
# ========================================
WEBHOOK_URL=https://your-webhook.com/receive

# ========================================
# HOW TO GET THESE VALUES
# ========================================

# M-PESA (Safaricom):
# 1. Register at: https://developer.safaricom.co.ke
# 2. Create an app in the Daraja portal
# 3. Copy Consumer Key and Consumer Secret
# 4. Get Business Short Code from your Safaricom account
# 5. Get Passkey from Safaricom portal

# EMAIL (Gmail):
# 1. Go to myaccount.google.com/apppasswords
# 2. Create app-specific password (16 characters)
# 3. Use this password (not your regular Gmail password)

# AFRICA'S TALKING:
# 1. Register at: https://africastalking.com
# 2. Get API Key from dashboard
# 3. Get Username from dashboard

# CALLBACK URL:
# 1. Deploy your backend to a public domain
# 2. Use format: https://your-domain.com/api/mpesa/callback
