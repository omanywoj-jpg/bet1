<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&family=Orbitron:wght@700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #FFD234;
    --red: #FF3333;
    --dark: #0A0A0F;
    --card: #111118;
    --border: #222230;
    --text: #E8E8F0;
    --muted: #6666AA;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--dark);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
    cursor: default;
  }

  /* === NOISE OVERLAY === */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 9999; opacity: 0.4;
  }

  /* === NAV === */
  nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.2rem 2rem;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0;
    background: rgba(10,10,15,0.92);
    backdrop-filter: blur(12px);
    z-index: 100;
  }

  .logo {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.4rem; font-weight: 900;
    letter-spacing: 0.05em;
    color: var(--gold);
    text-shadow: 0 0 20px rgba(255,210,52,0.4);
  }
  .logo span { color: var(--red); }

  nav ul {
    display: flex; gap: 2rem; list-style: none;
  }
  nav a {
    color: var(--muted); text-decoration: none;
    font-size: 0.85rem; font-weight: 500;
    letter-spacing: 0.08em; text-transform: uppercase;
    transition: color 0.2s;
  }
  nav a:hover { color: var(--gold); }

  .nav-cta {
    background: var(--gold); color: #000;
    padding: 0.5rem 1.2rem; border-radius: 4px;
    font-weight: 500; font-size: 0.85rem;
    text-transform: uppercase; letter-spacing: 0.06em;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 0 20px rgba(255,210,52,0.3);
  }
  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 30px rgba(255,210,52,0.5);
    color: #000;
  }

  /* === HERO === */
  .hero {
    min-height: 88vh;
    display: grid; place-items: center;
    text-align: center;
    padding: 4rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 60%, rgba(255,210,52,0.06) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 20% 80%, rgba(255,51,51,0.08) 0%, transparent 60%);
  }

  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,210,52,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,210,52,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 80%);
  }

  .hero-content { position: relative; z-index: 1; max-width: 800px; }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.75rem; font-weight: 500;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(255,210,52,0.3);
    padding: 0.3rem 1rem; border-radius: 2px;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.6s ease both;
  }

  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 0.92;
    letter-spacing: 0.02em;
    color: var(--text);
    animation: fadeUp 0.7s ease 0.1s both;
  }
  h1 em {
    font-style: normal;
    color: var(--gold);
    text-shadow: 0 0 40px rgba(255,210,52,0.5);
  }

  .hero-sub {
    margin-top: 1.5rem;
    font-size: 1.1rem; font-weight: 300;
    color: var(--muted); max-width: 480px; margin-inline: auto;
    line-height: 1.7;
    animation: fadeUp 0.7s ease 0.2s both;
  }

  .hero-actions {
    margin-top: 2.5rem;
    display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
    animation: fadeUp 0.7s ease 0.3s both;
  }

  .btn-primary {
    background: var(--gold); color: #000;
    padding: 0.9rem 2.2rem; border-radius: 4px;
    font-weight: 500; font-size: 0.95rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    text-decoration: none; border: none; cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 0 30px rgba(255,210,52,0.35);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 40px rgba(255,210,52,0.55);
  }

  .btn-ghost {
    background: transparent; color: var(--text);
    padding: 0.9rem 2.2rem; border-radius: 4px;
    font-weight: 500; font-size: 0.95rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    text-decoration: none; border: 1px solid var(--border); cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

  .hero-stats {
    margin-top: 4rem;
    display: flex; gap: 3rem; justify-content: center; flex-wrap: wrap;
    animation: fadeUp 0.7s ease 0.4s both;
  }
  .stat { text-align: center; }
  .stat-num {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.8rem; font-weight: 700;
    color: var(--gold);
  }
  .stat-label {
    font-size: 0.75rem; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.12em;
    margin-top: 0.2rem;
  }

  /* === SECTIONS === */
  section { padding: 5rem 2rem; max-width: 1200px; margin: 0 auto; }

  .section-label {
    font-size: 0.72rem; font-weight: 500;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 0.8rem;
  }

  h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: 0.02em;
    color: var(--text);
    margin-bottom: 1rem;
  }

  /* === CATEGORIES === */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    margin-top: 3rem;
  }

  .cat-card {
    background: var(--card);
    padding: 2.5rem 2rem;
    display: flex; flex-direction: column; gap: 1rem;
    cursor: pointer;
    transition: background 0.2s;
    position: relative; overflow: hidden;
  }
  .cat-card::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s;
  }
  .cat-card:hover { background: #151520; }
  .cat-card:hover::after { transform: scaleX(1); }

  .cat-icon { font-size: 2rem; }
  .cat-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem; letter-spacing: 0.05em;
    color: var(--text);
  }
  .cat-count {
    font-size: 0.78rem; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.1em;
  }

  /* === LIVE BETS === */
  .live-section { border-top: 1px solid var(--border); }

  .live-badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: rgba(255,51,51,0.15);
    border: 1px solid rgba(255,51,51,0.3);
    color: var(--red);
    font-size: 0.72rem; font-weight: 500;
    letter-spacing: 0.15em; text-transform: uppercase;
    padding: 0.25rem 0.7rem; border-radius: 2px;
    margin-bottom: 1rem;
  }
  .live-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--red);
    animation: pulse 1.4s ease infinite;
  }

  .bets-list {
    display: flex; flex-direction: column; gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px; overflow: hidden;
    margin-top: 2rem;
  }

  .bet-row {
    background: var(--card);
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    padding: 1.2rem 1.5rem;
    gap: 1rem;
    transition: background 0.15s;
    cursor: pointer;
  }
  .bet-row:hover { background: #151520; }

  .bet-info { display: flex; flex-direction: column; gap: 0.3rem; }
  .bet-event {
    font-size: 0.95rem; font-weight: 500; color: var(--text);
  }
  .bet-meta {
    font-size: 0.75rem; color: var(--muted);
    display: flex; gap: 1rem;
  }

  .bet-odds {
    display: flex; gap: 0.5rem;
  }
  .odd-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.8rem; font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
    min-width: 64px; text-align: center;
  }
  .odd-btn:hover {
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(255,210,52,0.06);
    box-shadow: 0 0 12px rgba(255,210,52,0.15);
  }
  .odd-btn.hot {
    border-color: rgba(255,51,51,0.4);
    color: var(--red);
  }
  .odd-label { font-size: 0.6rem; font-weight: 400; display: block; color: var(--muted); }

  /* === GAMES GRID === */
  .games-section { border-top: 1px solid var(--border); }

  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .game-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.2s, border-color 0.2s;
  }
  .game-card:hover { transform: translateY(-4px); border-color: rgba(255,210,52,0.3); }

  .game-thumb {
    height: 130px;
    display: flex; align-items: center; justify-content: center;
    font-size: 3.5rem;
    position: relative; overflow: hidden;
  }
  .game-thumb::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at center, rgba(255,255,255,0.05), transparent 70%);
  }

  .game-info { padding: 0.9rem 1rem; }
  .game-name {
    font-weight: 500; font-size: 0.9rem; color: var(--text);
  }
  .game-rtp {
    font-size: 0.72rem; color: var(--muted); margin-top: 0.2rem;
  }
  .game-rtp span { color: var(--gold); }

  /* === PROMO BANNER === */
  .promo {
    margin: 2rem auto;
    max-width: 1200px;
    padding: 0 2rem;
  }
  .promo-inner {
    background: linear-gradient(135deg, #1a1208 0%, #0e0e18 50%, #120a08 100%);
    border: 1px solid rgba(255,210,52,0.2);
    border-radius: 8px;
    padding: 3rem;
    display: flex; align-items: center; justify-content: space-between;
    gap: 2rem; flex-wrap: wrap;
    position: relative; overflow: hidden;
  }
  .promo-inner::before {
    content: '🎰';
    position: absolute; right: 2rem; bottom: -1rem;
    font-size: 8rem; opacity: 0.07;
    transform: rotate(-10deg);
  }
  .promo-text h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem; line-height: 1;
    color: var(--gold);
  }
  .promo-text p {
    color: var(--muted); font-size: 0.9rem; margin-top: 0.5rem;
  }
  .promo-badge {
    background: var(--gold); color: #000;
    font-family: 'Orbitron', sans-serif;
    font-size: 1.8rem; font-weight: 900;
    padding: 1rem 2rem; border-radius: 6px;
    white-space: nowrap;
    box-shadow: 0 0 40px rgba(255,210,52,0.4);
  }

  /* === FOOTER === */
  footer {
    border-top: 1px solid var(--border);
    padding: 3rem 2rem;
    text-align: center;
    color: var(--muted); font-size: 0.8rem;
    line-height: 2;
  }
  footer .f-logo {
    font-family: 'Orbitron', sans-serif;
    font-size: 1rem; color: var(--gold);
    margin-bottom: 1rem;
  }
  footer .disclaimer {
    max-width: 500px; margin: 1rem auto 0;
    font-size: 0.72rem; color: #44445a;
    line-height: 1.7;
  }

  /* === ANIMATIONS === */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.8); }
  }

  /* === TICKER === */
  .ticker-wrap {
    background: rgba(255,210,52,0.05);
    border-top: 1px solid rgba(255,210,52,0.1);
    border-bottom: 1px solid rgba(255,210,52,0.1);
    padding: 0.6rem 0; overflow: hidden;
  }
  .ticker {
    display: flex; gap: 4rem;
    animation: ticker 30s linear infinite;
    width: max-content;
  }
  .ticker-item {
    font-size: 0.75rem; font-weight: 500;
    color: var(--muted); white-space: nowrap;
    letter-spacing: 0.06em;
  }
  .ticker-item .up { color: #22dd88; }
  .ticker-item .down { color: var(--red); }
  @keyframes ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (max-width: 600px) {
    nav ul { display: none; }
    .bet-odds { flex-wrap: wrap; }
    .promo-inner { flex-direction: column; text-align: center; }
  }
</style>
</head>
